# 数据目录配置
# 本地开发默认使用项目根目录；Hugging Face Spaces 使用 /data；阿里云 ECS 建议 /var/lib/graduation-photo-selector
# DATA_DIR=/var/lib/graduation-photo-selector

# 班级访问密码（分享在班级群）
CLASS_PASSWORD=你的班级密码

# 管理员密码
ADMIN_PASSWORD=admin123

# 截止时间（ISO 8601 格式，如 2024-06-30T23:59:59）
DEADLINE=2024-12-31T23:59:59

# 每人需要选择的照片数量（默认8张，管理员可修改）
SELECTION_COUNT=8

# 阿里云 OSS 配置（用于照片读取，如果照片已公开访问则不需要）
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key
OSS_ACCESS_KEY_SECRET=your-access-secret
OSS_ENDPOINT=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# OSS 照片根目录（扫描该目录下的子文件夹作为分类）
# 例如：江南中学毕业照/  或留空表示扫描根目录
OSS_ROOT_PREFIX=

# 启动时自动扫描 OSS（默认 true，照片较多或 HF Spaces 冷启动超时可设为 false）
AUTO_SCAN_ON_START=true

# 阿里云人脸识别配置（可选，用于按人脸聚合照片）
# FACE_ENABLED=true
# FACE_ALIYUN_ACCESS_KEY_ID=your-access-key
# FACE_ALIYUN_ACCESS_KEY_SECRET=your-access-secret
# FACE_ALIYUN_ENDPOINT=facebody.cn-shanghai.aliyuncs.com
# FACE_DB_NAME=graduation-photo-selector
